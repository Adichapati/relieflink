# Frontend env vars (must be prefixed with VITE_ to be exposed to client code).
# Copy to web/.env.local for local dev. Production values go in the Vercel dashboard.

# Firebase web SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# API base URL.
#   Local dev: leave blank — defaults to http://localhost:8787
#   Vercel:    set to /api  (the serverless function lives at the same origin)
VITE_API_BASE=
