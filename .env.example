# Server-side env vars (used by api/ on Vercel and functions/ locally).
# In production set these in the Vercel dashboard. Do NOT commit real values.

# Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Firebase Admin SDK service account.
# Local dev: place serviceAccountKey.json under functions/src/ instead.
# Production: paste the entire JSON file contents as a single line.
FIREBASE_SERVICE_ACCOUNT=
